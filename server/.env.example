# Skerry Sync — конфигурация сервера (модель «один .env»). Скопируйте в .env и заполните.
# Все значения опциональны, кроме SKERRY_JWT_SECRET в проде.

# Сетевой интерфейс и порт.
SKERRY_HOST=0.0.0.0
SKERRY_PORT=8080

# Хранилище. По умолчанию SQLite-файл; для PostgreSQL замените URL и задайте user/password.
SKERRY_DB_URL=jdbc:sqlite:skerry-sync.db
# SKERRY_DB_URL=jdbc:postgresql://localhost:5432/skerry
SKERRY_DB_USER=
SKERRY_DB_PASSWORD=

# Подпись JWT. ОБЯЗАТЕЛЬНО задайте длинный случайный секрет в проде:
#   openssl rand -base64 48
# При смене секрета все выданные токены становятся недействительными.
SKERRY_JWT_SECRET=dev-insecure-change-me
SKERRY_JWT_ISSUER=skerry-sync

# Время жизни токенов и pairing-сессий (секунды).
SKERRY_ACCESS_TTL=900
SKERRY_REFRESH_TTL=2592000
SKERRY_PAIRING_TTL=300

# Срок хранения tombstone-записей (дни).
SKERRY_TOMBSTONE_DAYS=90

# Токен админ-консоли (/console и /admin/stats). Пустой ⇒ статистика закрыта.
SKERRY_ADMIN_TOKEN=

# Локальная разработка без устойчивого секрета: SKERRY_DEV=1 снимает fail-fast guard на
# дефолтный JWT-секрет. В проде НЕ задавать — задавайте реальный SKERRY_JWT_SECRET.
SKERRY_DEV=

# CORS-источники для браузерных клиентов (через запятую), напр. https://app.example.com.
# Пусто ⇒ CORS не включается (нативным клиентам он не нужен, консоль — same-origin).
SKERRY_CORS_HOSTS=
